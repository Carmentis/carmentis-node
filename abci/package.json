{
    "name": "abci",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "LGPL-3.0-or-later",
    "engines": {
        "node": ">=22.18.0"
    },
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:profiling": "node --prof dist/src/main.js",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "gen:proto": "node scripts/gen-proto.js",
        "gen:config:md": "ts-node scripts/generate-config-doc.ts"
    },
    "dependencies": {
        "@bufbuild/protobuf": "^2.12.0",
        "@cmts-dev/carmentis-sdk-core": "^1.2.12",
        "@grpc/grpc-js": "^1.14.3",
        "@grpc/proto-loader": "^0.8.0",
        "@grpc/reflection": "^1.0.4",
        "@iarna/toml": "^2.2.5",
        "@logtape/file": "^2.0.5",
        "@logtape/logtape": "^2.0.5",
        "@logtape/otel": "^2.0.5",
        "@nestjs/axios": "^4.0.1",
        "@nestjs/common": "^11",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11",
        "@nestjs/microservices": "^11",
        "@nestjs/platform-express": "^11",
        "@nestjs/platform-socket.io": "^11",
        "@nestjs/platform-ws": "^11",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/websockets": "^11",
        "@noble/secp256k1": "^3.0.0",
        "abstract-level": "^3.1.1",
        "cbor-x": "^1.6.4",
        "get-port": "^7.2.0",
        "level": "^10.0.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "ts-proto": "^2.11.6",
        "valibot": "^1.3.1",
        "wire": "link:@bufbuild/protobuf/wire",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.17",
        "@nestjs/testing": "^11",
        "@protobuf-ts/plugin": "^2.11.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "jest": "^30.3.0",
        "prettier": "^3.8.1",
        "protoc": "^34.0.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "ts-protoc-gen": "^0.15.0",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
